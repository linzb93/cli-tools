{
    "name": "cli-tools",
    "version": "7.2.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "packageManager": "pnpm@9.1.4",
    "scripts": {
        "dev": "npm run dev:cli",
        "dev:ui": "pnpm --filter \"ui\" dev",
        "dev:cli": "pnpm --filter \"@cli-tools/cli\" dev",
        "dev:web": "pnpm --filter \"@cli-tools/server\" dev",
        "mon:web": "nodemon packages/server/dist/web.js --watch packages/server/dist",
        "gen:features": "node scripts/generateFeatures.js",
        "build": "npm run gen:features && pnpm --filter \"@cli-tools/cli\" build",
        "build:report": "pnpm --filter \"@cli-tools/cli\" build:report",
        "build:web": "pnpm --filter \"@cli-tools/server\" build",
        "build:server-legacy": "pnpm --filter \"@cli-tools/server-legacy\" build",
        "build:ui": "pnpm --filter \"@cli-tools/ui\" build-only",
        "build:context": "pnpm --filter \"@cli-tools/windows-context\" build",
        "build:vscode": "cd packages/vscode-extension && npx @vscode/vsce package --allow-missing-repository --skip-license --no-dependencies --out dist/",
        "build:web-all": "npm run build:web && npm run build:ui",
        "check": "pnpm --filter \"@cli-tools/cli\" check",
        "release": "standard-version",
        "server-legacy": "node packages/server-legacy/dist/index.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "@linzb93/utils": "^0.0.14",
        "@types/react": "^19.2.14",
        "axios": "1.6.8",
        "body-parser": "^1.20.2",
        "chalk": "^5.3.0",
        "cli-table3": "^0.6.5",
        "cors": "^2.8.5",
        "dayjs": "^1.9.6",
        "express": "^5.2.1",
        "fs-extra": "^11.3.0",
        "lodash-es": "^4.17.21",
        "lowdb": "^7.0.1",
        "nodemon": "^3.1.14",
        "p-map": "^7.0.4",
        "prettier": "^3.2.5",
        "react": "^19.2.4",
        "sass": "^1.74.1",
        "tsx": "^4.21.0"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/fs-extra": "^11.0.4",
        "@types/glob": "^7.2.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^20.19.0",
        "cross-env": "^7.0.3",
        "husky": "^9.0.11",
        "rollup-plugin-visualizer": "^6.0.5",
        "standard-version": "^9.5.0",
        "typescript": "^6.0.2",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}
