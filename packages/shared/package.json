{
    "name": "@cli-tools/shared",
    "version": "7.4.0",
    "description": "A cli for personal use",
    "type": "module",
    "private": true,
    "keywords": [
        "cli"
    ],
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./node": {
            "types": "./src/node.ts",
            "default": "./dist/node.js"
        },
        "./*": {
            "types": "./src/*",
            "default": "./dist/*"
        }
    },
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "vite build",
        "test": "vitest run"
    },
    "author": "linzb93",
    "license": "ISC"
}
