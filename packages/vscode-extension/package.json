{
    "name": "vscode-extension",
    "type": "module",
    "publisher": "my-publisher",
    "displayName": "cli-vscode-extension",
    "description": "cli use",
    "version": "7.4.0",
    "engines": {
        "vscode": "^1.107.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/index.js",
    "contributes": {
        "commands": [
            {
                "command": "mycli.copyFilePathAndLine",
                "title": "复制文件地址和行号"
            },
            {
                "command": "mycli.startVueBuildedProject",
                "title": "启动已打包的项目"
            }
        ],
        "submenus": [
            {
                "id": "mycli.submenu",
                "label": "mycli"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "mycli.copyFilePathAndLine",
                    "when": "editorHasSelection",
                    "group": "2_files"
                }
            ],
            "explorer/context": [
                {
                    "command": "mycli.startVueBuildedProject",
                    "when": "explorerResourceIsFolder",
                    "group": "2_files"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "compile": "vite build",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@types/vscode": "^1.107.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1"
    }
}
